#!/usr/bin/env bash

set -o errexit -o nounset -o pipefail

DOTFILES_ROOT="${DOTFILES_ROOT:-$(cd "$(dirname "$0")/../.." && pwd)}"
DOTFILES_OS="${DOTFILES_OS:-macos}"

copy_or_link_file() {
  local source="$1"
  local target="$2"

  mkdir -p "$(dirname "$target")"

  if [[ "$DOTFILES_OS" == "windows" ]]; then
    cp -f "$source" "$target"
  else
    ln -sf "$source" "$target"
  fi
}

echo "==> Ensuring shell/git directories exist"
mkdir -p "$HOME/.config/git"
if [[ "$DOTFILES_OS" != "windows" ]]; then
  mkdir -p "$HOME/.config/zsh" "$HOME/.local/state/zsh"
fi
echo "--> Shell/git directories ready"

echo "==> Installing shell/git configuration"
for F in $(find "$DOTFILES_ROOT"/git "$DOTFILES_ROOT"/terminal -type f -not -name '.*'); do
  filename=$(basename "$F")
  rel="${F#$DOTFILES_ROOT/}"
  case "$rel" in
    "terminal/zshenv") [[ "$DOTFILES_OS" != "windows" ]] && copy_or_link_file "$F" "$HOME/.zshenv" ;;
    "terminal/zshrc") [[ "$DOTFILES_OS" != "windows" ]] && copy_or_link_file "$F" "$HOME/.config/zsh/.zshrc" ;;
    "terminal/tigrc") copy_or_link_file "$F" "$HOME/.tigrc" ;;
    "terminal/tmux.conf") [[ "$DOTFILES_OS" != "windows" ]] && copy_or_link_file "$F" "$HOME/.tmux.conf" ;;
    "terminal/"*) [[ "$DOTFILES_OS" != "windows" ]] && copy_or_link_file "$F" "$HOME/.config/zsh/$filename" ;;

    "git/config") copy_or_link_file "$F" "$HOME/.config/git/config" ;;
    "git/ignore") copy_or_link_file "$F" "$HOME/.config/git/ignore" ;;
  esac
done
echo "--> Shell/git configuration installed"
