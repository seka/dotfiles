#!/usr/bin/env bash

set -o errexit -o nounset -o pipefail

if ! command -v gh >/dev/null 2>&1; then
  echo "gh not found. Skipping AI agent skill installation."
  exit 0
fi

AGENTS=(
  "github-copilot"
  "claude-code"
  "codex"
  "gemini-cli"
)

AWESOME_COPILOT_SKILLS=(
  "lsp-setup"
  "acquire-codebase-knowledge"
  "context-map"
  "refactor-plan"
  "prd"
  "breakdown-test"
  "web-design-reviewer"
)

echo "Installing awesome-copilot skills..."
for skill in "${AWESOME_COPILOT_SKILLS[@]}"; do
  for agent in "${AGENTS[@]}"; do
    gh skill install github/awesome-copilot "$skill" --agent "$agent" --scope user --force
  done
done
echo "awesome-copilot skills installed."

PM_SKILLS=(
  "skills/foundation-stakeholder-update"
  "skills/foundation-meeting-agenda"
  "skills/foundation-meeting-brief"
  "skills/foundation-meeting-recap"
  "skills/foundation-meeting-synthesize"
  "skills/foundation-stakeholder-briefings"
  "skills/discover-interview-synthesis"
  "skills/discover-stakeholder-summary"
  "skills/define-problem-statement"
  "skills/define-hypothesis"
  "skills/develop-adr"
)

echo "Installing pm-skills skills..."
for skill in "${PM_SKILLS[@]}"; do
  for agent in "${AGENTS[@]}"; do
    gh skill install product-on-purpose/pm-skills "$skill" --agent "$agent" --scope user --force
  done
done
echo "pm-skills skills installed."

echo "Installing crit plugins..."
if command -v crit >/dev/null 2>&1; then
  (
    cd ~
    crit install github-copilot
  ) || echo "crit github-copilot install skipped or failed."

  (
    cd ~
    crit install gemini
  ) || echo "crit gemini install skipped or failed."

  (
    cd ~
    crit install codex-plugin
  ) || echo "crit codex-plugin install skipped or failed."
fi

if command -v claude >/dev/null 2>&1; then
  claude plugin marketplace add tomasz-tomczyk/crit || echo "claude crit marketplace already exists or failed."
  claude plugin install crit@crit || echo "claude crit plugin already installed or failed."
fi
echo "crit plugins installed."
